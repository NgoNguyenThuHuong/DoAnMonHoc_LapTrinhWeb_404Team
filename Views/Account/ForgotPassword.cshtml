@model LingoToneMVC.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LingoTone AI</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body class="auth-page">
    <div class="glass-card auth-card">
        <div class="auth-logo">
            <div class="auth-logo-icon"><span>L</span></div>
            <h1 class="auth-title m-0 ms-3">LingoTone AI</h1>
        </div>
        <h2 class="auth-title" style="font-size:24px;">Quên mật khẩu? 🔒</h2>
        <p class="auth-subtitle">Nhập email của bạn để nhận liên kết khôi phục.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-error">
                <i class="fas fa-exclamation-circle me-2"></i>
                @Html.ValidationSummary(true, "")
            </div>
        }

        <form asp-action="ForgotPassword" method="post">
            <div class="form-group mb-4">
                <label asp-for="Email" class="form-label">Email đã đăng ký</label>
                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <button type="submit" class="auth-submit-btn">Gửi liên kết khôi phục</button>
        </form>

        <div class="auth-link mt-4">
            <a href="/Account/Login"><i class="fas fa-arrow-left me-1"></i> Quay lại đăng nhập</a>
        </div>
    </div>
</body>
</html>
