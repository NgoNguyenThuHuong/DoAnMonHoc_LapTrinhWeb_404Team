@{
    ViewData["Title"] = "Gửi email thành công";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LingoTone AI</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body class="auth-page">
    <div class="glass-card auth-card text-center">
        <div class="auth-logo justify-content-center mb-4">
            <div class="auth-logo-icon" style="background: linear-gradient(135deg, #28a745, #20c997);">
                <i class="fas fa-check" style="color: white; font-size: 24px;"></i>
            </div>
        </div>
        <h2 class="auth-title" style="font-size:24px;">Đã gửi liên kết! ✉️</h2>
        <p class="auth-subtitle mb-4">Vui lòng kiểm tra hộp thư đến (và thư mục rác) để đặt lại mật khẩu của bạn.</p>

        <a href="/Account/Login" class="auth-submit-btn d-inline-block text-decoration-none">
            Quay lại đăng nhập
        </a>
    </div>
</body>
</html>
