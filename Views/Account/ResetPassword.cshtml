@model LingoToneMVC.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LingoTone AI</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body class="auth-page">
    <div class="glass-card auth-card">
        <div class="auth-logo">
            <div class="auth-logo-icon"><span>L</span></div>
            <h1 class="auth-title m-0 ms-3">LingoTone AI</h1>
        </div>
        <h2 class="auth-title" style="font-size:24px;">Đặt lại mật khẩu 🔑</h2>
        <p class="auth-subtitle">Nhập mật khẩu mới cho tài khoản của bạn.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-error">
                <i class="fas fa-exclamation-circle me-2"></i>
                @Html.ValidationSummary(true, "")
            </div>
        }

        <form asp-action="ResetPassword" method="post">
            <input asp-for="Code" type="hidden" />
            
            <div class="form-group">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Mật khẩu mới</label>
                <input asp-for="Password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>

            <button type="submit" class="auth-submit-btn">Đổi mật khẩu</button>
        </form>
    </div>
</body>
</html>
