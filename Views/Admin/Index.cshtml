@{
    ViewData["Title"] = "Trang quản trị";
}

<style>
    .admin-stat-card {
        background: white;
        border-radius: 20px;
        padding: 28px 24px;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .admin-stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }
    .admin-icon {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: white;
        margin-bottom: 16px;
    }
    .admin-link-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px 24px;
        background: white;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.05);
        text-decoration: none;
        color: #1e293b;
        transition: all 0.2s;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .admin-link-card:hover {
        background: #f8fafc;
        box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        color: #1e293b;
        transform: translateX(4px);
    }
</style>

<div class="animate-fade-in">
    <div class="d-flex align-items-center mb-4">
        <div style="width:56px;height:56px;background:linear-gradient(135deg,#ef4444,#f97316);border-radius:16px;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 16px rgba(239,68,68,0.2);margin-right:16px;">
            <i class="fa-solid fa-shield-halved text-white fs-4"></i>
        </div>
        <div>
            <h2 class="fw-bold m-0" style="font-size:24px;color:#1e293b;">Trang quản trị</h2>
            <p class="text-secondary m-0" style="font-size:14px;">Quản lý hệ thống LingoTone AI</p>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="admin-stat-card text-center">
                <div class="admin-icon mx-auto" style="background:linear-gradient(135deg,#3b82f6,#6366f1);">
                    <i class="fa-solid fa-users"></i>
                </div>
                <div class="fw-bold" style="font-size:28px;color:#1e293b;">@(ViewBag.TotalUsers ?? 0)</div>
                <div class="text-secondary" style="font-size:13px;">Người dùng</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="admin-stat-card text-center">
                <div class="admin-icon mx-auto" style="background:linear-gradient(135deg,#10b981,#059669);">
                    <i class="fa-solid fa-book-open"></i>
                </div>
                <div class="fw-bold" style="font-size:28px;color:#1e293b;">@(ViewBag.TotalLessons ?? 0)</div>
                <div class="text-secondary" style="font-size:13px;">Bài học</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="admin-stat-card text-center">
                <div class="admin-icon mx-auto" style="background:linear-gradient(135deg,#f59e0b,#d97706);">
                    <i class="fa-solid fa-language"></i>
                </div>
                <div class="fw-bold" style="font-size:28px;color:#1e293b;">@(ViewBag.TotalVocabs ?? 0)</div>
                <div class="text-secondary" style="font-size:13px;">Từ vựng</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="admin-stat-card text-center">
                <div class="admin-icon mx-auto" style="background:linear-gradient(135deg,#8b5cf6,#7c3aed);">
                    <i class="fa-solid fa-circle-question"></i>
                </div>
                <div class="fw-bold" style="font-size:28px;color:#1e293b;">@(ViewBag.TotalQuizQuestions ?? 0)</div>
                <div class="text-secondary" style="font-size:13px;">Câu hỏi Quiz</div>
            </div>
        </div>
    </div>

    <!-- Nav -->
    <div class="glass-card card" style="border-radius:24px;padding:28px;">
        <h5 class="fw-bold mb-4" style="color:#1e293b;">Quản lý hệ thống</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <a asp-controller="Admin" asp-action="Lessons" class="admin-link-card">
                    <div style="width:44px;height:44px;background:rgba(16,185,129,0.1);border-radius:12px;display:flex;align-items:center;justify-content:center;color:#10b981;flex-shrink:0;">
                        <i class="fa-solid fa-book-open fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold" style="font-size:15px;">Quản lý bài học</div>
                        <div class="text-secondary" style="font-size:13px;">Xem danh sách bài học và từ vựng</div>
                    </div>
                    <i class="fa-solid fa-arrow-right text-secondary ms-auto"></i>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Admin" asp-action="Vocabularies" class="admin-link-card">
                    <div style="width:44px;height:44px;background:rgba(245,158,11,0.1);border-radius:12px;display:flex;align-items:center;justify-content:center;color:#f59e0b;flex-shrink:0;">
                        <i class="fa-solid fa-language fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold" style="font-size:15px;">Quản lý từ vựng</div>
                        <div class="text-secondary" style="font-size:13px;">Xem và kiểm tra từ vựng trong hệ thống</div>
                    </div>
                    <i class="fa-solid fa-arrow-right text-secondary ms-auto"></i>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Admin" asp-action="Quizzes" class="admin-link-card">
                    <div style="width:44px;height:44px;background:rgba(139,92,246,0.1);border-radius:12px;display:flex;align-items:center;justify-content:center;color:#8b5cf6;flex-shrink:0;">
                        <i class="fa-solid fa-trophy fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold" style="font-size:15px;">Quản lý Quiz</div>
                        <div class="text-secondary" style="font-size:13px;">Xem câu hỏi quiz của từng bài học</div>
                    </div>
                    <i class="fa-solid fa-arrow-right text-secondary ms-auto"></i>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Admin" asp-action="Users" class="admin-link-card">
                    <div style="width:44px;height:44px;background:rgba(59,130,246,0.1);border-radius:12px;display:flex;align-items:center;justify-content:center;color:#3b82f6;flex-shrink:0;">
                        <i class="fa-solid fa-users fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold" style="font-size:15px;">Quản lý người dùng</div>
                        <div class="text-secondary" style="font-size:13px;">Xem danh sách và phân quyền tài khoản</div>
                    </div>
                    <i class="fa-solid fa-arrow-right text-secondary ms-auto"></i>
                </a>
            </div>
        </div>
    </div>
</div>
