@model IEnumerable<LingoToneMVC.Models.ApplicationUser>
@{
    ViewData["Title"] = "Quản lý người dùng";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
}

<div class="animate-fade-in">
    <div class="d-flex align-items-center mb-4">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-light me-3" style="border-radius:12px;">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div>
            <h2 class="fw-bold m-0" style="font-size:22px;color:#1e293b;">Quản lý người dùng</h2>
            <p class="text-secondary m-0" style="font-size:13px;">@Model.Count() tài khoản trong hệ thống</p>
        </div>
    </div>

    <div class="glass-card card" style="border-radius:24px;padding:24px;">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr style="font-size:13px;color:#64748b;font-weight:600;">
                        <th>Tên hiển thị</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>XP</th>
                        <th>Level</th>
                        <th>Đăng nhập cuối</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var roles = userRoles?.ContainsKey(user.Id) == true ? userRoles[user.Id] : new List<string>();
                        var isAdmin = roles.Contains("Admin");
                        <tr>
                            <td class="fw-bold" style="font-size:14px;">@(user.DisplayName ?? user.UserName)</td>
                            <td class="text-secondary" style="font-size:13px;">@user.Email</td>
                            <td>
                                @if (isAdmin)
                                {
                                    <span class="badge" style="background:rgba(239,68,68,0.1);color:#ef4444;border-radius:8px;padding:4px 10px;font-size:12px;">
                                        <i class="fa-solid fa-shield-halved me-1"></i>Admin
                                    </span>
                                }
                                else
                                {
                                    <span class="badge" style="background:rgba(59,130,246,0.1);color:#3b82f6;border-radius:8px;padding:4px 10px;font-size:12px;">
                                        <i class="fa-solid fa-user me-1"></i>User
                                    </span>
                                }
                            </td>
                            <td class="fw-bold text-success">@user.XP XP</td>
                            <td>Lv.@user.Level</td>
                            <td class="text-secondary" style="font-size:13px;">@(user.LastLoginDate.HasValue ? user.LastLoginDate.Value.ToString("dd/MM/yyyy") : "–")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
