@model IEnumerable<LingoToneMVC.Models.Vocabulary>
@{
    ViewData["Title"] = "Quản lý từ vựng";
}

<div class="animate-fade-in">
    <div class="d-flex align-items-center mb-4">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-light me-3" style="border-radius:12px;">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div>
            <h2 class="fw-bold m-0" style="font-size:22px;color:#1e293b;">Quản lý từ vựng</h2>
            <p class="text-secondary m-0" style="font-size:13px;">Hiển thị 200 từ vựng gần nhất</p>
        </div>
    </div>

    <div class="glass-card card" style="border-radius:24px;padding:24px;">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr style="font-size:13px;color:#64748b;font-weight:600;">
                        <th>Chữ Hán</th>
                        <th>Pinyin</th>
                        <th>Nghĩa tiếng Việt</th>
                        <th>Bài học</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model)
                    {
                        var hasVietnamese = !string.IsNullOrEmpty(v.Vietnamese) && v.Vietnamese != "Đang dịch...";
                        <tr>
                            <td class="fw-bold" style="font-size:20px;">@v.Chinese</td>
                            <td class="text-secondary" style="font-size:14px;">@v.Pinyin</td>
                            <td id="vi-td-@v.Id">
                                @if (hasVietnamese)
                                {
                                    <span style="font-size:14px;">@v.Vietnamese</span>
                                }
                                else
                                {
                                    <span class="text-secondary" style="font-size:13px;" id="vi-text-@v.Id">Chưa có nghĩa</span>
                                    <button class="btn btn-sm btn-outline-primary ms-2" onclick="translateVocab(@v.Id, this)" id="btn-trans-@v.Id">
                                        <i class="fa-solid fa-language"></i> Dịch
                                    </button>
                                }
                            </td>
                            <td class="text-secondary" style="font-size:13px;">@(v.Lesson?.Title)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    async function translateVocab(id, btn) {
        const textSpan = document.getElementById('vi-text-' + id);
        
        // UI Loading State
        const originalBtnHtml = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang dịch...';
        btn.disabled = true;
        
        try {
            const response = await fetch('/Admin/TranslateVocabulary/' + id, {
                method: 'POST'
            });
            const data = await response.json();
            
            if (data.success) {
                // Success
                document.getElementById('vi-td-' + id).innerHTML = `<span style="font-size:14px;">${data.vietnamese}</span>`;
            } else {
                // Error (Fallback/Timeout/Overload)
                textSpan.innerHTML = `<span class="text-danger"><i class="fa-solid fa-triangle-exclamation me-1"></i> ${data.message}</span>`;
                btn.innerHTML = originalBtnHtml;
                btn.disabled = false;
            }
        } catch (err) {
            textSpan.innerHTML = `<span class="text-danger"><i class="fa-solid fa-triangle-exclamation me-1"></i> Lỗi kết nối.</span>`;
            btn.innerHTML = originalBtnHtml;
            btn.disabled = false;
        }
    }
</script>
}
