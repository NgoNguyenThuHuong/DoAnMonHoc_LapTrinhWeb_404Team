@{
    ViewData["Title"] = "Học tiếng Trung thông minh";
}

<section class="landing-hero animate-fade-in">
    <div>
        <span class="hsk-badge">Boya • HSK • Smart SRS</span>
        <h1 class="hero-title">
            Học tiếng Trung <br />
            thông minh bằng <span class="hero-gradient-text">AI</span>
        </h1>
        <p class="hero-description mt-3">
            LingoTone kết hợp giáo trình Boya, HSK, phát âm, Quiz và Smart SRS giúp bạn học tiếng Trung mỗi ngày hiệu quả hơn.
        </p>

        <div class="d-flex gap-3 mt-4">
            <a href="/Lesson" class="btn btn-primary btn-lg rounded-pill px-5">
                Học ngay <i class="fa-solid fa-arrow-right ms-2"></i>
            </a>
            <a href="/Quiz" class="btn btn-light btn-lg rounded-pill px-5 border shadow-sm">
                Xem Demo
            </a>
        </div>
    </div>

    <div class="hero-demo-card glass-card">
        <div class="d-flex justify-content-between mb-3">
            <span class="hsk-badge">HSK 1</span>
            <span class="text-warning fw-bold">
                <i class="fa-solid fa-fire"></i> 3 Day Streak
            </span>
        </div>

        <div class="chinese-big">你好</div>
        <div class="pinyin-text">nǐ hǎo</div>
        <p class="text-muted">Xin chào</p>

        <div class="mt-4">
            <div class="d-flex justify-content-between small fw-bold">
                <span>Tiến độ bài học</span>
                <span class="text-success">75%</span>
            </div>
            <div class="progress mt-2" style="height: 8px;">
                <div class="progress-bar bg-success" style="width:75%"></div>
            </div>
        </div>
    </div>
</section>

<section class="feature-grid mt-5">
    <div class="feature-card">
        <i class="fa-solid fa-book-open fa-2x text-success mb-3"></i>
        <h4 class="fw-bold">Boya Lessons</h4>
        <p class="text-secondary">Học theo lộ trình giáo trình Boya từ cơ bản đến nâng cao.</p>
    </div>
    <div class="feature-card">
        <i class="fa-solid fa-language fa-2x text-primary mb-3"></i>
        <h4 class="fw-bold">Thư viện Hán tự</h4>
        <p class="text-secondary">Tra cứu pinyin, Hán Việt, bộ thủ, số nét và cấp độ HSK.</p>
    </div>
    <div class="feature-card">
        <i class="fa-solid fa-microphone fa-2x text-danger mb-3"></i>
        <h4 class="fw-bold">Phát âm</h4>
        <p class="text-secondary">Luyện nghe và đọc tiếng Trung với ví dụ thực tế.</p>
    </div>
    <div class="feature-card">
        <i class="fa-solid fa-brain fa-2x text-warning mb-3"></i>
        <h4 class="fw-bold">Smart SRS</h4>
        <p class="text-secondary">Ôn tập thông minh giúp ghi nhớ lâu hơn.</p>
    </div>
</section>

<div class="py-5 text-center mt-5 mb-5 edtech-card p-5" style="background: linear-gradient(135deg, rgba(16,185,129,0.05), rgba(59,130,246,0.05));">
    <h2 class="fw-bold mb-3" style="font-size: 36px;">Sẵn sàng bắt đầu hành trình tiếng Trung?</h2>
    <p class="text-secondary mb-4 fs-5">Hàng ngàn bài học và từ vựng đang chờ đón bạn.</p>
    <div class="d-flex justify-content-center gap-3">
        <a href="/Account/Register" class="btn btn-primary px-5 py-3 rounded-pill fw-bold shadow-sm" style="background: #1e293b; border: none; font-size: 16px;">Đăng ký miễn phí</a>
        <a href="/Lesson" class="btn btn-outline-dark px-5 py-3 rounded-pill fw-bold" style="border: 2px solid #e2e8f0; font-size: 16px;">Khám phá bài học</a>
    </div>
</div>

<!-- Footer -->
<footer class="text-center py-4 border-top mt-5 text-secondary">
    <div class="fw-bold fs-5 mb-2" style="color: #1e293b;"><i class="fa-solid fa-graduation-cap text-primary me-2"></i>LingoTone AI</div>
    <p class="mb-1" style="font-size: 14px;">Đồ án môn Lập trình Web</p>
    <p class="mb-0" style="font-size: 13px; opacity: 0.8;">Xây dựng bằng ASP.NET Core MVC + SQL Server</p>
</footer>
