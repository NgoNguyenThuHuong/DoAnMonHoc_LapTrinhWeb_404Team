@{
    ViewData["Title"] = "AI HSK Estimator";
}

<style>
    .hsk-feature-item {
        display: flex;
        gap: 16px;
        align-items: center;
        margin-bottom: 12px;
    }
    .hsk-feature-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    
    .hsk-score-circle {
        position: relative;
        width: 160px;
        height: 160px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        background: conic-gradient(#10b981 30%, #3b82f6 30% 60%, #e2e8f0 60%);
    }
    .hsk-score-circle-inner {
        width: 140px;
        height: 140px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }
    
    .skill-progress-row { margin-bottom: 20px; }
    .skill-progress-row:last-child { margin-bottom: 0; }
    .skill-label { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 6px; }
    .skill-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-right: 12px; flex-shrink: 0; }
    .skill-bar-container { height: 6px; border-radius: 3px; background: rgba(0,0,0,0.05); overflow: hidden; }
    .skill-bar-fill { height: 100%; border-radius: 3px; }
    
    .strength-list li { margin-bottom: 12px; color: #4b5563; font-size: 13px; position: relative; padding-left: 20px; }
    .strength-list li::before {
        content: '\f00c';
        font-family: 'Font Awesome 6 Free';
        font-weight: 900;
        color: #10b981;
        position: absolute;
        left: 0;
        top: 2px;
        font-size: 10px;
    }
    .weakness-list li { margin-bottom: 12px; color: #4b5563; font-size: 13px; position: relative; padding-left: 20px; }
    .weakness-list li::before {
        content: '\f00c';
        font-family: 'Font Awesome 6 Free';
        font-weight: 900;
        color: #ef4444;
        position: absolute;
        left: 0;
        top: 2px;
        font-size: 10px;
    }
    
    .roadmap-step {
        text-align: center;
        position: relative;
        flex: 1;
        padding: 0 10px;
    }
    .roadmap-step::after {
        content: '';
        position: absolute;
        top: 20px;
        right: -50%;
        width: 100%;
        height: 2px;
        background: rgba(0,0,0,0.05);
        border-top: 2px dashed rgba(0,0,0,0.1);
        z-index: 1;
    }
    .roadmap-step:last-child::after { display: none; }
    .roadmap-number {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        margin: 0 auto 12px;
        position: relative;
        z-index: 2;
        background: white;
    }
</style>

<div class="animate-fade-in">
    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center gap-3">
            <div style="width: 56px; height: 56px; background: linear-gradient(135deg, #0ea5e9, #3b82f6); border-radius: 16px; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 16px rgba(14,165,233,0.2);">
                <i class="fa-solid fa-chart-pie text-white fs-4"></i>
            </div>
            <div>
                <h2 class="fw-bold m-0" style="font-size: 24px; color: #1e293b;">AI HSK Estimator</h2>
                <p class="text-secondary m-0" style="font-size: 14px;">Dự đoán trình độ HSK của bạn qua bài test ngắn</p>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-light rounded-pill px-4 fw-bold" style="border: 1px solid rgba(0,0,0,0.05); font-size: 14px;">
                <i class="fa-regular fa-circle-question me-2"></i> Hướng dẫn
            </button>
            <button class="btn btn-light rounded-pill px-4 fw-bold" style="border: 1px solid rgba(0,0,0,0.05); font-size: 14px;">
                <i class="fa-solid fa-clock-rotate-left me-2"></i> Lịch sử kiểm tra
            </button>
        </div>
    </div>

    <!-- Top Banner -->
    <div class="glass-card card mb-4" style="border-radius: 24px; padding: 32px; background: white;">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h4 class="fw-bold text-dark mb-3">Đánh giá trình độ HSK qua đoạn văn</h4>
                <p class="text-secondary mb-3" style="font-size: 14px; line-height: 1.6;">AI sẽ phân tích từ vựng, ngữ pháp và cấu trúc câu trong đoạn văn tiếng Trung của bạn để dự đoán cấp độ HSK hiện tại.</p>
                <textarea id="hsk-input" class="form-control" rows="4" placeholder="Nhập một đoạn văn tiếng Trung (khoảng 50-200 chữ) để AI phân tích..." style="border-radius: 16px; background: rgba(0,0,0,0.02); border: 1px solid rgba(0,0,0,0.05); padding: 16px; font-size: 14px; resize: none; margin-bottom: 16px;"></textarea>
            </div>
                <div class="hsk-feature-item">
                    <div class="hsk-feature-icon" style="background: rgba(59,130,246,0.1); color: #3b82f6;"><i class="fa-solid fa-shield-halved"></i></div>
                    <div>
                        <div class="fw-bold text-dark" style="font-size: 13px;">Dự đoán chính xác</div>
                        <div class="text-secondary" style="font-size: 11px;">AI phân tích toàn diện 4 kỹ năng</div>
                    </div>
                </div>
                <div class="hsk-feature-item">
                    <div class="hsk-feature-icon" style="background: rgba(16,185,129,0.1); color: #10b981;"><i class="fa-solid fa-stopwatch"></i></div>
                    <div>
                        <div class="fw-bold text-dark" style="font-size: 13px;">Nhanh chóng</div>
                        <div class="text-secondary" style="font-size: 11px;">Hoàn thành trong 15-20 phút</div>
                    </div>
                </div>
                <div class="hsk-feature-item m-0">
                    <div class="hsk-feature-icon" style="background: rgba(139,92,246,0.1); color: #8b5cf6;"><i class="fa-solid fa-user-astronaut"></i></div>
                    <div>
                        <div class="fw-bold text-dark" style="font-size: 13px;">Cá nhân hóa</div>
                        <div class="text-secondary" style="font-size: 11px;">Gợi ý lộ trình học phù hợp cho bạn</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 d-flex flex-column align-items-end justify-content-center">
                <button class="btn btn-light rounded-circle mb-3" style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.03); border: none;" onclick="document.getElementById('hsk-input').value=''"><i class="fa-solid fa-rotate-right text-secondary"></i></button>
                <button id="btn-estimate" onclick="estimateLevel()" class="btn btn-primary w-100 fw-bold py-3 mb-2" style="border-radius: 12px; background: linear-gradient(135deg, #10b981, #3b82f6); border: none; box-shadow: 0 8px 24px rgba(59,130,246,0.25);">
                    <i class="fa-solid fa-rocket me-2"></i> Phân tích ngay
                </button>
                <div class="text-secondary text-center w-100" style="font-size: 11px;">Thời gian ước tính: ~5 giây</div>
            </div>
        </div>
    </div>

    <!-- Middle Stats Row -->
    <div class="row g-4 mb-4">
        <!-- Left: Ket qua du doan -->
        <div class="col-lg-3">
            <div class="glass-card card h-100 text-center d-flex flex-column" style="border-radius: 24px; padding: 24px;">
                <h5 class="fw-bold text-dark text-start mb-4" style="font-size: 16px;">Kết quả dự đoán</h5>
                
                <div class="hsk-score-circle mx-auto mb-3">
                    <div class="hsk-score-circle-inner">
                        <div id="estimated-hsk-text" class="fw-bold text-dark" style="font-size: 32px; line-height: 1.2;">HSK 2</div>
                        <div class="text-secondary" style="font-size: 12px; font-weight: 500;">Trình độ dự đoán</div>
                    </div>
                </div>

                <div class="text-warning fs-5 mb-3">
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-regular fa-star"></i>
                    <i class="fa-regular fa-star"></i>
                </div>

                <p id="hsk-message" class="text-secondary mb-4 px-2" style="font-size: 13px; line-height: 1.6;">Bạn đã nắm vững kiến thức cơ bản. Hãy tiếp tục luyện tập để đạt HSK 3!</p>
                
                <div class="mt-auto">
                    <div class="badge" style="background: rgba(59,130,246,0.1); color: #3b82f6; font-size: 12px; font-weight: bold; padding: 8px 16px; border-radius: 8px;">
                        HSK 2 (150 - 300 điểm) <i class="fa-solid fa-circle-info ms-1 opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Middle: Phan tich nang luc -->
        <div class="col-lg-5">
            <div class="glass-card card h-100" style="border-radius: 24px; padding: 24px;">
                <h5 class="fw-bold text-dark mb-4" style="font-size: 16px;">Phân tích năng lực</h5>
                
                <div class="skill-progress-row d-flex align-items-center">
                    <div class="skill-icon" style="background: rgba(59,130,246,0.1); color: #3b82f6;"><i class="fa-solid fa-headphones"></i></div>
                    <div class="flex-grow-1">
                        <div class="skill-label">
                            <div>
                                <div class="fw-bold text-dark" style="font-size: 14px;">Nghe hiểu</div>
                                <div class="text-secondary" style="font-size: 11px;">Hiểu các đoạn hội thoại ngắn, thông tin cơ bản</div>
                            </div>
                            <span id="listen-score" class="fw-bold" style="color: #3b82f6; font-size: 13px;">65/100</span>
                        </div>
                        <div class="skill-bar-container"><div id="listen-bar" class="skill-bar-fill" style="width: 65%; background: #3b82f6;"></div></div>
                    </div>
                </div>

                <div class="skill-progress-row d-flex align-items-center">
                    <div class="skill-icon" style="background: rgba(16,185,129,0.1); color: #10b981;"><i class="fa-solid fa-book-open"></i></div>
                    <div class="flex-grow-1">
                        <div class="skill-label">
                            <div>
                                <div class="fw-bold text-dark" style="font-size: 14px;">Từ vựng</div>
                                <div class="text-secondary" style="font-size: 11px;">Khoảng 300 - 600 từ vựng</div>
                            </div>
                            <span id="vocab-score" class="fw-bold" style="color: #10b981; font-size: 13px;">72/100</span>
                        </div>
                        <div class="skill-bar-container"><div id="vocab-bar" class="skill-bar-fill" style="width: 72%; background: #10b981;"></div></div>
                    </div>
                </div>

                <div class="skill-progress-row d-flex align-items-center">
                    <div class="skill-icon" style="background: rgba(139,92,246,0.1); color: #8b5cf6;"><i class="fa-solid fa-pen"></i></div>
                    <div class="flex-grow-1">
                        <div class="skill-label">
                            <div>
                                <div class="fw-bold text-dark" style="font-size: 14px;">Ngữ pháp</div>
                                <div class="text-secondary" style="font-size: 11px;">Nắm vững cấu trúc cơ bản</div>
                            </div>
                            <span id="grammar-score" class="fw-bold" style="color: #8b5cf6; font-size: 13px;">60/100</span>
                        </div>
                        <div class="skill-bar-container"><div id="grammar-bar" class="skill-bar-fill" style="width: 60%; background: #8b5cf6;"></div></div>
                    </div>
                </div>

                <div class="skill-progress-row d-flex align-items-center">
                    <div class="skill-icon" style="background: rgba(245,158,11,0.1); color: #f59e0b;"><i class="fa-solid fa-message"></i></div>
                    <div class="flex-grow-1">
                        <div class="skill-label">
                            <div>
                                <div class="fw-bold text-dark" style="font-size: 14px;">Đọc hiểu</div>
                                <div class="text-secondary" style="font-size: 11px;">Hiểu đoạn văn ngắn, chủ đề quen thuộc</div>
                            </div>
                            <span id="read-score" class="fw-bold" style="color: #f59e0b; font-size: 13px;">68/100</span>
                        </div>
                        <div class="skill-bar-container"><div id="read-bar" class="skill-bar-fill" style="width: 68%; background: #f59e0b;"></div></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Strengths & Weaknesses -->
        <div class="col-lg-4 d-flex flex-column gap-4">
            <div class="glass-card card flex-grow-1" style="border-radius: 20px; padding: 24px;">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div style="width: 24px; height: 24px; background: rgba(16,185,129,0.1); color: #10b981; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px;"><i class="fa-solid fa-check"></i></div>
                    <h6 class="fw-bold m-0 text-dark">Điểm mạnh</h6>
                </div>
                <ul id="strength-list" class="list-unstyled m-0 strength-list">
                    <li>Nhận biết từ vựng chủ đề quen thuộc</li>
                    <li>Hiểu câu đơn và câu ghép cơ bản</li>
                    <li>Có khả năng giao tiếp tình huống đơn giản</li>
                </ul>
            </div>
            
            <div class="glass-card card flex-grow-1" style="border-radius: 20px; padding: 24px;">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div style="width: 24px; height: 24px; background: rgba(239,68,68,0.1); color: #ef4444; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px;"><i class="fa-solid fa-triangle-exclamation"></i></div>
                    <h6 class="fw-bold m-0 text-dark">Điểm cần cải thiện</h6>
                </div>
                <ul id="weakness-list" class="list-unstyled m-0 weakness-list">
                    <li>Ngữ pháp phức tạp (把, 被, 使...)</li>
                    <li>Nghe hiểu đoạn hội thoại dài hơn</li>
                    <li>Từ vựng học thuật và chủ đề nâng cao</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Bottom Row: Roadmap & AI Advice -->
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="glass-card card h-100" style="border-radius: 24px; padding: 24px;">
                <h5 class="fw-bold text-dark mb-4" style="font-size: 16px;">Gợi ý lộ trình học</h5>
                
                <div class="d-flex w-100 px-2 pt-2">
                    <div class="roadmap-step">
                        <div class="roadmap-number" style="color: #10b981; border: 2px solid #10b981; background: rgba(16,185,129,0.1);">1</div>
                        <div class="fw-bold text-dark mb-1" style="font-size: 13px;">Củng cố HSK 2</div>
                        <div class="text-secondary mb-2" style="font-size: 11px;">Ôn tập từ vựng và ngữ pháp cơ bản</div>
                        <div class="text-secondary fw-bold" style="font-size: 11px;">1 - 2 tuần</div>
                    </div>
                    
                    <div class="roadmap-step">
                        <div class="roadmap-number" style="color: white; border: 2px solid #3b82f6; background: #3b82f6; box-shadow: 0 4px 12px rgba(59,130,246,0.3);">2</div>
                        <div class="fw-bold text-dark mb-1" style="font-size: 13px;">Nâng cao HSK 3</div>
                        <div class="text-secondary mb-2" style="font-size: 11px;">Mở rộng vốn từ và cấu trúc câu phức</div>
                        <div class="text-primary fw-bold" style="font-size: 11px;">4 - 6 tuần</div>
                    </div>
                    
                    <div class="roadmap-step">
                        <div class="roadmap-number" style="color: #8b5cf6; border: 2px solid #8b5cf6; background: white;">3</div>
                        <div class="fw-bold text-dark mb-1" style="font-size: 13px;">Luyện kỹ năng</div>
                        <div class="text-secondary mb-2" style="font-size: 11px;">Tăng cường nghe, đọc và giao tiếp</div>
                        <div class="text-secondary fw-bold" style="font-size: 11px;">4 - 6 tuần</div>
                    </div>
                    
                    <div class="roadmap-step">
                        <div class="roadmap-number" style="color: #f59e0b; border: 2px solid #f59e0b; background: white;">4</div>
                        <div class="fw-bold text-dark mb-1" style="font-size: 13px;">Đạt HSK 3+</div>
                        <div class="text-secondary mb-2" style="font-size: 11px;">Luyện đề và kỹ năng làm bài thi</div>
                        <div class="text-secondary fw-bold" style="font-size: 11px;">2 - 4 tuần</div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="glass-card card h-100" style="border-radius: 24px; padding: 24px; background: rgba(59,130,246,0.03); border: 1px solid rgba(59,130,246,0.1);">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="fa-solid fa-robot text-primary fs-5"></i>
                    <h6 class="fw-bold m-0 text-dark">Lời khuyên từ AI</h6>
                </div>
                
                <p id="ai-advice" class="text-secondary" style="font-size: 13px; line-height: 1.8; margin-bottom: 24px;">Bạn đang ở mức HSK 2, đây là nền tảng tốt! Hãy học mỗi ngày 30 phút, tập trung vào việc mở rộng từ vựng và luyện nghe. Đừng quên áp dụng vào giao tiếp thực tế nhé! 💪</p>
                
                <div class="mt-auto text-end">
                    <a href="#" class="btn text-primary fw-bold p-0 d-inline-flex align-items-center gap-2 text-decoration-none" style="font-size: 13px;">
                        Xem bài học phù hợp <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('hsk-input').value = "我叫小明，我今年二十岁，我是学生。我在越南学习中文已经两年了。我喜欢中文，因为中文很有趣，而且很有用。";

    async function estimateLevel() {
        const btn = document.getElementById('btn-estimate');
        const text = document.getElementById('hsk-input').value.trim();
        
        if (text.length === 0) {
            alert('Vui lòng nhập đoạn văn để phân tích.');
            return;
        }

        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> AI đang phân tích...';
        btn.disabled = true;

        try {
            const response = await fetch('/Ai/EstimateHskLevel', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ text: text })
            });
            const data = await response.json();
            
            if (data.estimatedLevel) {
                // Populate Dashboard
                document.getElementById('estimated-hsk-text').innerText = data.estimatedLevel;
                document.getElementById('hsk-message').innerText = data.levelMessage || '';
                
                document.getElementById('listen-score').innerText = `${data.listeningScore}/100`;
                document.getElementById('listen-bar').style.width = `${data.listeningScore}%`;
                
                document.getElementById('vocab-score').innerText = `${data.vocabScore}/100`;
                document.getElementById('vocab-bar').style.width = `${data.vocabScore}%`;
                
                document.getElementById('grammar-score').innerText = `${data.grammarScore}/100`;
                document.getElementById('grammar-bar').style.width = `${data.grammarScore}%`;
                
                document.getElementById('read-score').innerText = `${data.readingScore}/100`;
                document.getElementById('read-bar').style.width = `${data.readingScore}%`;
                
                const strengths = data.strengths || [];
                document.getElementById('strength-list').innerHTML = strengths.map(s => `<li>${s}</li>`).join('');
                
                const weaknesses = data.weaknesses || [];
                document.getElementById('weakness-list').innerHTML = weaknesses.map(s => `<li>${s}</li>`).join('');
                
                document.getElementById('ai-advice').innerText = data.aiAdvice || '';
            } else {
                alert("Lỗi phân tích: " + (data.message || "Không có phản hồi"));
            }
        } catch (error) {
            console.error("Error estimating level:", error);
            alert("Đã xảy ra lỗi kết nối với máy chủ AI.");
        } finally {
            btn.innerHTML = '<i class="fa-solid fa-rocket me-2"></i> Phân tích ngay';
            btn.disabled = false;
        }
    }
</script>
}
