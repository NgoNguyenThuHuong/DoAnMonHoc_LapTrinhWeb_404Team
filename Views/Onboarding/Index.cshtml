@{
    Layout = null;
    ViewData["Title"] = "LingoTone AI - Thiết lập lộ trình";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #f0fdf4 0%, #eff6ff 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            color: #1e293b;
        }

        .onboarding-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 40px;
            width: 100%;
            max-width: 600px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
            border: 1px solid rgba(255,255,255,0.6);
            position: relative;
            overflow: hidden;
        }

        .step-container {
            display: none;
            animation: fadeIn 0.5s ease;
        }

        .step-container.active {
            display: block;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .option-card {
            border: 2px solid rgba(0,0,0,0.05);
            border-radius: 16px;
            padding: 20px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 16px;
            background: white;
            margin-bottom: 12px;
        }

        .option-card:hover {
            border-color: rgba(59,130,246,0.3);
            background: rgba(59,130,246,0.02);
            transform: translateY(-2px);
        }

        .option-card.selected {
            border-color: #3B82F6;
            background: rgba(59,130,246,0.05);
            box-shadow: 0 4px 12px rgba(59,130,246,0.1);
        }

        .option-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            background: #f8fafc;
        }

        .option-card.selected .option-icon {
            background: #3B82F6;
            color: white;
        }

        .ai-robot {
            font-size: 48px;
            color: #3B82F6;
            animation: bounce 2s infinite;
        }

        @@keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .progress-bar-ai {
            height: 8px;
            background: #e2e8f0;
            border-radius: 4px;
            overflow: hidden;
            margin-top: 24px;
        }

        .progress-fill-ai {
            height: 100%;
            background: linear-gradient(90deg, #3B82F6, #8B5CF6);
            width: 0%;
            transition: width 0.3s ease;
        }
    </style>
</head>
<body>

    <div class="onboarding-card">
        <!-- Step 1 -->
        <div id="step-1" class="step-container active">
            <div class="text-center mb-5">
                <div style="width: 64px; height: 64px; background: linear-gradient(135deg, #10B981, #3B82F6); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
                    <i class="fa-solid fa-graduation-cap text-white fs-3"></i>
                </div>
                <h2 class="fw-bold">Mục tiêu học tập của bạn là gì?</h2>
                <p class="text-secondary">AI sẽ dựa vào mục tiêu này để tối ưu hóa lộ trình</p>
            </div>

            <div class="options-group" id="goal-options">
                <div class="option-card" onclick="selectOption('goal', this, 'HSK')">
                    <div class="option-icon"><i class="fa-solid fa-file-signature"></i></div>
                    <div>
                        <div class="fw-bold" style="font-size: 16px;">Thi chứng chỉ HSK</div>
                        <div class="text-secondary" style="font-size: 13px;">Tập trung ngữ pháp và từ vựng học thuật</div>
                    </div>
                </div>
                <div class="option-card" onclick="selectOption('goal', this, 'GiaoTiep')">
                    <div class="option-icon"><i class="fa-solid fa-comments"></i></div>
                    <div>
                        <div class="fw-bold" style="font-size: 16px;">Giao tiếp cơ bản</div>
                        <div class="text-secondary" style="font-size: 13px;">Tập trung hội thoại và phát âm thực tế</div>
                    </div>
                </div>
                <div class="option-card" onclick="selectOption('goal', this, 'DuLich')">
                    <div class="option-icon"><i class="fa-solid fa-plane-departure"></i></div>
                    <div>
                        <div class="fw-bold" style="font-size: 16px;">Du lịch Trung Quốc</div>
                        <div class="text-secondary" style="font-size: 13px;">Giao tiếp mua sắm, hỏi đường, khách sạn</div>
                    </div>
                </div>
            </div>

            <div class="mt-4 text-end">
                <button onclick="nextStep(2)" class="btn btn-primary px-5 py-3 fw-bold rounded-pill" id="btn-step-1" disabled style="background: linear-gradient(135deg, #3B82F6, #2563eb); border: none;">Tiếp tục <i class="fas fa-arrow-right ms-2"></i></button>
            </div>
        </div>

        <!-- Step 2: Career -->
        <div id="step-2" class="step-container">
            <div class="text-center mb-5">
                <div style="width: 64px; height: 64px; background: linear-gradient(135deg, #8B5CF6, #3B82F6); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
                    <i class="fa-solid fa-briefcase text-white fs-3"></i>
                </div>
                <h2 class="fw-bold">Bạn làm trong lĩnh vực nào?</h2>
                <p class="text-secondary">AI sẽ tối ưu từ vựng và Roleplay theo chuyên ngành của bạn</p>
            </div>

            <div class="options-group" id="career-options" style="max-height: 300px; overflow-y: auto; padding-right: 10px;">
                <div class="option-card" onclick="selectOption('career', this, 'CNTT')">
                    <div class="option-icon"><i class="fa-solid fa-laptop-code"></i></div>
                    <div><div class="fw-bold" style="font-size: 16px;">Công nghệ thông tin</div></div>
                </div>
                <div class="option-card" onclick="selectOption('career', this, 'Logistics')">
                    <div class="option-icon"><i class="fa-solid fa-truck-fast"></i></div>
                    <div><div class="fw-bold" style="font-size: 16px;">Logistics & Xuất nhập khẩu</div></div>
                </div>
                <div class="option-card" onclick="selectOption('career', this, 'Marketing')">
                    <div class="option-icon"><i class="fa-solid fa-bullhorn"></i></div>
                    <div><div class="fw-bold" style="font-size: 16px;">Marketing & Truyền thông</div></div>
                </div>
                <div class="option-card" onclick="selectOption('career', this, 'KeToan')">
                    <div class="option-icon"><i class="fa-solid fa-calculator"></i></div>
                    <div><div class="fw-bold" style="font-size: 16px;">Tài chính - Kế toán</div></div>
                </div>
                <div class="option-card" onclick="selectOption('career', this, 'DuLich')">
                    <div class="option-icon"><i class="fa-solid fa-plane-departure"></i></div>
                    <div><div class="fw-bold" style="font-size: 16px;">Du lịch & Khách sạn</div></div>
                </div>
            </div>

            <div class="mt-4 d-flex justify-content-between">
                <button onclick="nextStep(1)" class="btn btn-light px-4 py-3 fw-bold rounded-pill text-secondary">Quay lại</button>
                <button onclick="nextStep(3)" class="btn btn-primary px-5 py-3 fw-bold rounded-pill" id="btn-step-2" disabled style="background: linear-gradient(135deg, #3B82F6, #2563eb); border: none;">Tiếp tục <i class="fas fa-arrow-right ms-2"></i></button>
            </div>
        </div>

        <!-- Step 3: Time -->
        <div id="step-3" class="step-container">
            <div class="text-center mb-5">
                <div style="width: 64px; height: 64px; background: linear-gradient(135deg, #F59E0B, #EF4444); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
                    <i class="fa-solid fa-clock text-white fs-3"></i>
                </div>
                <h2 class="fw-bold">Cam kết thời gian</h2>
                <p class="text-secondary">Bạn có thể dành bao nhiêu thời gian mỗi ngày?</p>
            </div>

            <div class="options-group" id="time-options">
                <div class="option-card" onclick="selectOption('time', this, '15')">
                    <div class="option-icon"><i class="fa-solid fa-stopwatch"></i></div>
                    <div>
                        <div class="fw-bold" style="font-size: 16px;">15 phút / ngày</div>
                        <div class="text-secondary" style="font-size: 13px;">Nhẹ nhàng, thư giãn (Duy trì thói quen)</div>
                    </div>
                </div>
                <div class="option-card" onclick="selectOption('time', this, '30')">
                    <div class="option-icon"><i class="fa-solid fa-fire"></i></div>
                    <div>
                        <div class="fw-bold" style="font-size: 16px;">30 phút / ngày</div>
                        <div class="text-secondary" style="font-size: 13px;">Tiêu chuẩn (Đề xuất bởi AI)</div>
                    </div>
                </div>
                <div class="option-card" onclick="selectOption('time', this, '60')">
                    <div class="option-icon"><i class="fa-solid fa-rocket"></i></div>
                    <div>
                        <div class="fw-bold" style="font-size: 16px;">60 phút / ngày</div>
                        <div class="text-secondary" style="font-size: 13px;">Cường độ cao (Tiến bộ nhanh nhất)</div>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex justify-content-between">
                <button onclick="nextStep(2)" class="btn btn-light px-4 py-3 fw-bold rounded-pill text-secondary">Quay lại</button>
                <button onclick="startAiProcess()" class="btn btn-primary px-5 py-3 fw-bold rounded-pill" id="btn-step-3" disabled style="background: linear-gradient(135deg, #3B82F6, #8B5CF6); border: none;">Hoàn tất <i class="fas fa-magic ms-2"></i></button>
            </div>
        </div>

        <!-- Step 4: AI Processing -->
        <div id="step-4" class="step-container text-center py-4">
            <i class="fa-solid fa-robot ai-robot mb-4"></i>
            <h2 class="fw-bold mb-3" id="ai-status">AI Đang phân tích...</h2>
            <p class="text-secondary" id="ai-detail">Đang xây dựng lộ trình học (Learning Twin) cho riêng bạn.</p>
            
            <div class="progress-bar-ai">
                <div class="progress-fill-ai" id="ai-progress"></div>
            </div>
        </div>
    </div>

    <script>
        const userSelections = {
            goal: null,
            career: null,
            time: null
        };

        function selectOption(category, element, value) {
            // Remove active class from siblings
            const parent = document.getElementById(`${category}-options`);
            const cards = parent.querySelectorAll('.option-card');
            cards.forEach(c => c.classList.remove('selected'));

            // Add active class to clicked
            element.classList.add('selected');

            // Save selection
            userSelections[category] = value;

            // Enable next button
            if (category === 'goal') {
                document.getElementById('btn-step-1').removeAttribute('disabled');
            } else if (category === 'career') {
                document.getElementById('btn-step-2').removeAttribute('disabled');
            } else if (category === 'time') {
                document.getElementById('btn-step-3').removeAttribute('disabled');
            }
        }

        function nextStep(step) {
            document.querySelectorAll('.step-container').forEach(c => c.classList.remove('active'));
            document.getElementById('step-' + step).classList.add('active');
        }

        function startAiProcess() {
            nextStep(4);
            
            const progress = document.getElementById('ai-progress');
            const status = document.getElementById('ai-status');
            const detail = document.getElementById('ai-detail');

            // Simulate AI Processing
            setTimeout(() => { progress.style.width = '30%'; detail.innerText = `Đang thiết lập cơ sở dữ liệu từ vựng chuyên ngành ${userSelections.career || 'chung'}...`; }, 800);
            setTimeout(() => { progress.style.width = '60%'; detail.innerText = 'Đang tùy chỉnh kịch bản Roleplay Teacher...'; }, 1800);
            setTimeout(() => { progress.style.width = '90%'; detail.innerText = 'Đang tối ưu lộ trình học cá nhân hóa...'; }, 2800);
            
            setTimeout(() => { 
                progress.style.width = '100%'; 
                status.innerText = 'Lộ trình đã hoàn tất!';
                status.style.color = '#10B981';
                detail.innerText = 'Đang chuyển hướng về Bảng điều khiển...';
                document.querySelector('.ai-robot').className = 'fa-solid fa-check-circle ai-robot text-success';
                
                // Save to localStorage so Dashboard knows
                localStorage.setItem('lingotone_onboarding', JSON.stringify(userSelections));

                setTimeout(() => {
                    window.location.href = '/';
                }, 1000);
            }, 3800);
        }
    </script>
</body>
</html>
