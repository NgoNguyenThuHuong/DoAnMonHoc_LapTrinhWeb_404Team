@model LingoToneMVC.ViewModels.QuizViewModel
@{
    ViewData["Title"] = "Quiz Arena";
}

<style>
    .quiz-info-card {
        background: rgba(0,0,0,0.02);
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 12px;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        flex: 1;
    }
    .quiz-info-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    
    .quiz-option {
        border: 1px solid rgba(0,0,0,0.1);
        border-radius: 12px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        cursor: pointer;
        transition: 0.2s;
        background: white;
    }
    .quiz-option:hover {
        background: rgba(0,0,0,0.02);
        border-color: rgba(0,0,0,0.2);
    }
    .quiz-option.active {
        border-color: #10b981;
        background: rgba(16,185,129,0.05);
    }
    .option-letter {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #64748b;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 12px;
        flex-shrink: 0;
    }
    .quiz-option.active .option-letter {
        background: #10b981;
    }
    
    .leaderboard-item {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 8px;
        background: white;
        border: 1px solid rgba(0,0,0,0.05);
    }
    .leaderboard-item.active {
        background: rgba(59,130,246,0.1);
        border-color: rgba(59,130,246,0.2);
    }
    .rank-circle {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 12px;
        color: white;
        margin-right: 16px;
    }
    .rank-1 { background: #f59e0b; }
    .rank-2 { background: #64748b; }
    .rank-3 { background: #d97706; }
    .rank-other { background: #94a3b8; }
    .rank-active { background: #3b82f6; }
    
    .stat-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    .stat-row:last-child { border-bottom: none; }
    
    .review-panel {
        margin-top: 24px;
        padding: 24px;
        background: #ffffff;
        border-radius: 24px;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 12px 40px rgba(15, 23, 42, 0.08);
        text-align: left;
    }
    .review-item {
        padding: 16px;
        border-radius: 16px;
        border: 1px solid #e5e7eb;
    }
    .review-item.correct {
        background: #ecfdf5;
        border-color: #a7f3d0;
    }
    .review-item.wrong {
        background: #fef2f2;
        border-color: #fecaca;
    }
    .review-option {
        padding: 8px 12px;
        border-radius: 8px;
        margin-bottom: 6px;
        border: 1px solid #e5e7eb;
        background: white;
        font-size: 14px;
    }
    .review-option.is-correct {
        background: #dcfce7;
        border-color: #22c55e;
        color: #15803d;
        font-weight: 600;
    }
    .review-option.is-wrong {
        background: #fee2e2;
        border-color: #ef4444;
        color: #b91c1c;
    }
</style>

<div class="animate-fade-in">
    <!-- Header -->
    <div class="d-flex align-items-center mb-4">
        <div style="width: 56px; height: 56px; background: linear-gradient(135deg, #2dd4bf, #10b981); border-radius: 16px; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 16px rgba(16,185,129,0.2); margin-right: 16px;">
            <i class="fa-solid fa-trophy text-white fs-4"></i>
        </div>
        <div>
            <h2 class="fw-bold m-0" style="font-size: 24px; color: #1e293b;">Quiz Arena</h2>
            <p class="text-secondary m-0" style="font-size: 14px;">Thách thức kiến thức – Nhận XP – Lên bảng xếp hạng</p>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }

    <div class="row g-4">
        <!-- Main Quiz Area -->
        <div class="col-lg-8">
            <div class="glass-card card h-100 d-flex flex-column" style="border-radius: 24px; padding: 24px;">
                
                <!-- Progress Header -->
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="badge" style="background: rgba(59,130,246,0.1); color: #3b82f6; font-weight: bold; padding: 6px 12px; border-radius: 999px;">
                        <i class="fa-regular fa-circle-question me-1"></i> Câu <span id="current-q-num">1</span>/@Model.Questions.Count
                    </span>
                    <span class="fw-bold text-warning" style="font-size: 13px;">
                        <i class="fa-solid fa-star me-1"></i> +20 XP/câu
                    </span>
                </div>
                <div style="height: 6px; background: rgba(0,0,0,0.05); border-radius: 3px; overflow: hidden; margin-bottom: 24px;">
                    <div id="progress-bar" style="height: 100%; width: 0%; background: linear-gradient(90deg, #8b5cf6, #3b82f6); border-radius: 3px; transition: width 0.3s;"></div>
                </div>

                <!-- Info Cards -->
                <div class="d-flex flex-wrap gap-3 mb-5">
                    <div class="quiz-info-card">
                        <div class="quiz-info-icon" style="background: rgba(59,130,246,0.1); color: #3b82f6;"><i class="fa-solid fa-folder"></i></div>
                        <div>
                            <div class="text-secondary" style="font-size: 11px; font-weight: 600;">Chủ đề:</div>
                            <div class="fw-bold text-dark" style="font-size: 13px;">@Model.LessonTitle</div>
                        </div>
                    </div>
                    <div class="quiz-info-card">
                        <div class="quiz-info-icon" style="background: rgba(16,185,129,0.1); color: #10b981;"><i class="fa-solid fa-check-double"></i></div>
                        <div>
                            <div class="text-secondary" style="font-size: 11px; font-weight: 600;">Cấp độ:</div>
                            <div class="fw-bold text-dark" style="font-size: 13px;">@Model.HskLevel</div>
                        </div>
                    </div>
                    <div class="quiz-info-card">
                        <div class="quiz-info-icon" style="background: rgba(139,92,246,0.1); color: #8b5cf6;"><i class="fa-solid fa-star"></i></div>
                        <div>
                            <div class="text-secondary" style="font-size: 11px; font-weight: 600;">Điểm hiện tại:</div>
                            <div class="fw-bold text-dark" style="font-size: 13px;" id="current-xp">0 XP</div>
                        </div>
                    </div>
                </div>

                @if (Model.Questions == null || !Model.Questions.Any())
                {
                    <div class="empty-state text-center py-5">
                        <h3 class="fw-bold text-secondary">Chưa có câu hỏi cho bài học này</h3>
                        <p class="text-muted">Vui lòng tạo dữ liệu Quiz cho bài học trước.</p>
                        <form asp-controller="Quiz" asp-action="GenerateQuiz" method="post" class="mt-4">
                            <input type="hidden" name="lessonId" value="@Model.LessonId" />
                            <button type="submit" class="btn btn-primary" style="border-radius: 12px;">
                                <i class="fa-solid fa-robot"></i> Tạo Quiz bằng AI
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    @Html.AntiForgeryToken()
                    <!-- Question Area -->
                    <div class="text-center flex-grow-1 d-flex flex-column justify-content-center mb-5" id="question-area">
                        <!-- Content inserted via JS -->
                    </div>

                    <!-- Options -->
                    <div class="row g-3 mb-5" id="options-area">
                        <!-- Options generated here -->
                    </div>

                    <!-- Explanation Area -->
                    <div id="explanation-area" class="alert alert-info" style="display:none; border-radius: 16px;">
                    </div>

                    <!-- Bottom Actions -->
                    <div class="mt-auto d-flex justify-content-between align-items-center border-top pt-4" id="quiz-actions">
                        <button class="btn btn-light fw-bold px-4 d-flex align-items-center gap-2" style="border-radius: 12px; color: #64748b; border: 1px solid rgba(0,0,0,0.1);" onclick="skipQuestion()">
                            <i class="fa-solid fa-forward-step"></i> Bỏ qua
                        </button>
                        <button id="btn-next" class="btn fw-bold px-4 py-2 d-flex align-items-center gap-2" style="border-radius: 12px; background: #10b981; color: white; border: none; box-shadow: 0 4px 12px rgba(16,185,129,0.2);" onclick="nextQuestion()" disabled>
                            Câu tiếp theo <i class="fa-solid fa-arrow-right"></i>
                        </button>
                    </div>
                    
                    <div id="quiz-finished" style="display:none;" class="text-center">
                        <div class="mb-4">
                            <div style="width: 80px; height: 80px; background: #ecfdf5; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
                                <i class="fa-solid fa-check-double text-success" style="font-size: 40px;"></i>
                            </div>
                            <h3 class="text-success fw-bold">Hoàn thành!</h3>
                            <p class="text-secondary">Bạn đã trả lời xong bộ câu hỏi.</p>
                        </div>
                        
                        <div class="d-flex justify-content-center flex-wrap gap-3">
                            <button type="button" id="reviewAnswersBtn" class="btn fw-bold d-flex align-items-center gap-2" style="background: rgba(59,130,246,0.1); color: #3b82f6; border-radius: 12px; padding: 12px 24px; border: none;">
                                <i class="fa-solid fa-clipboard-list"></i> Xem lại đáp án
                            </button>
                            <button type="button" id="retryQuizBtn" class="btn btn-light fw-bold d-flex align-items-center gap-2" style="color: #64748b; border-radius: 12px; padding: 12px 24px; border: 1px solid rgba(0,0,0,0.1);">
                                <i class="fa-solid fa-rotate-right"></i> Làm lại
                            </button>
                            <a href="/Lesson/Detail/@Model.LessonId" class="btn btn-success fw-bold d-flex align-items-center gap-2" style="border-radius: 12px; padding: 12px 24px; box-shadow: 0 4px 12px rgba(16,185,129,0.2);">
                                <i class="fa-solid fa-arrow-left"></i> Quay lại bài học
                            </a>
                        </div>
                    </div>

                    <div id="reviewPanel" class="review-panel" style="display: none;">
                        <div class="review-header border-bottom pb-3 mb-4 d-flex justify-content-between align-items-center">
                            <h4 class="fw-bold m-0"><i class="fa-solid fa-clipboard-check text-primary me-2"></i> Xem lại đáp án</h4>
                            <button type="button" id="closeReviewBtn" class="btn btn-sm btn-light" style="border-radius: 8px;">
                                <i class="fa-solid fa-xmark"></i> Đóng
                            </button>
                        </div>
                        <div id="reviewList" class="d-flex flex-column gap-3"></div>
                    </div>
                }

            </div>
        </div>

        <!-- Right Column: Stats & Leaderboard -->
        <div class="col-lg-4 d-flex flex-column gap-4">
            
            <!-- Bảng xếp hạng tuần -->
            <div class="glass-card card" style="border-radius: 24px; padding: 24px; flex: 1;">
                <div class="d-flex align-items-center gap-2 mb-4">
                    <i class="fa-solid fa-trophy text-warning fs-5"></i>
                    <h5 class="fw-bold m-0 text-dark" style="font-size: 16px;">Bảng xếp hạng tuần</h5>
                </div>
                
                @if (Model.WeeklyLeaderboard == null || !Model.WeeklyLeaderboard.Any())
                {
                    <div class="text-center text-secondary py-3">
                        <i class="fa-solid fa-ghost fs-3 mb-2 opacity-50"></i>
                        <p class="mb-0" style="font-size: 13px;">Chưa có ai tham gia tuần này. Hãy là người đầu tiên!</p>
                    </div>
                }
                else
                {
                    @foreach (var item in Model.WeeklyLeaderboard)
                    {
                        <div class="leaderboard-item @(item.IsCurrentUser ? "active mt-3" : "")">
                            <div class="rank-circle @(item.Rank == 1 ? "rank-1" : item.Rank == 2 ? "rank-2" : item.Rank == 3 ? "rank-3" : item.IsCurrentUser ? "rank-active" : "rank-other")">@item.Rank</div>
                            <div class="fw-bold @(item.IsCurrentUser ? "text-primary" : "text-dark") flex-grow-1">@(item.IsCurrentUser ? "Bạn" : item.UserName)</div>
                            <div class="@(item.Rank == 1 ? "fw-bold text-warning" : item.IsCurrentUser ? "fw-bold text-primary" : "text-secondary fw-bold")" @(item.IsCurrentUser ? "id=lb-xp" : "")>@item.XP XP</div>
                        </div>
                    }
                }
            </div>

            <!-- Thống kê phiên chơi -->
            <div class="glass-card card" style="border-radius: 24px; padding: 24px; background: rgba(59,130,246,0.02);">
                <div class="d-flex align-items-center gap-2 mb-4">
                    <i class="fa-solid fa-chart-simple text-primary fs-5"></i>
                    <h5 class="fw-bold m-0 text-dark" style="font-size: 16px;">Thống kê phiên chơi</h5>
                </div>
                
                <div>
                    <div class="stat-row">
                        <span class="text-secondary" style="font-size: 14px; font-weight: 500;">Số câu đúng</span>
                        <span class="fw-bold text-success" id="stat-correct">0/0</span>
                    </div>
                    <div class="stat-row">
                        <span class="text-secondary" style="font-size: 14px; font-weight: 500;">Combo hiện tại</span>
                        <span class="fw-bold text-dark" id="stat-combo">0</span>
                    </div>
                    <div class="stat-row">
                        <span class="text-secondary" style="font-size: 14px; font-weight: 500;">Combo Max</span>
                        <span class="fw-bold text-dark" id="stat-max-combo">0</span>
                    </div>
                    <div class="stat-row border-0 pb-0">
                        <span class="text-secondary" style="font-size: 14px; font-weight: 500;">Tổng XP nhận được</span>
                        <span class="fw-bold text-primary" id="stat-xp">0</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
@if (Model.Questions != null && Model.Questions.Any())
{
<script>
    const questions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Questions.Select(q => new { id = q.Id, question = q.Question, optionA = q.OptionA, optionB = q.OptionB, optionC = q.OptionC, optionD = q.OptionD, correctAnswer = q.CorrectAnswer, explanation = q.Explanation, xpReward = q.XpReward }), new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
    const lessonId = @Model.LessonId;
    let currentIdx = -1;
    let xp = parseInt(localStorage.getItem('lingo_xp') || '0');
    let sessionXp = 0;
    let correctCount = 0;
    let totalAnswered = 0;
    let currentCombo = 0;
    let maxCombo = 0;
    let answered = false;
    let userAnswers = [];
    let reviewData = [];

    document.getElementById('lb-xp').innerText = xp + ' XP';

    function nextQuestion() {
        currentIdx++;
        if (currentIdx >= questions.length) {
            finishQuiz();
            return;
        }
        
        document.getElementById('current-q-num').innerText = currentIdx + 1;
        document.getElementById('progress-bar').style.width = ((currentIdx) / questions.length * 100) + '%';
        
        loadQuestion();
    }

    function loadQuestion() {
        answered = false;
        document.getElementById('btn-next').disabled = true;
        document.getElementById('explanation-area').style.display = 'none';
        
        const q = questions[currentIdx];
        
        document.getElementById('question-area').innerHTML = `
            <div class="fw-bold text-dark mb-4" style="font-size: 32px; line-height: 1.4;">${q.question}</div>
        `;

        const letters = ['A', 'B', 'C', 'D'];
        const options = [q.optionA, q.optionB, q.optionC, q.optionD];
        
        let optionsHtml = '';
        options.forEach((opt, idx) => {
            optionsHtml += `
            <div class="col-md-6">
                <div class="quiz-option" id="opt-${idx}" onclick="selectOption(${idx}, '${letters[idx]}')">
                    <div class="option-letter">${letters[idx]}</div>
                    <div class="fw-bold text-dark" style="font-size: 15px;">${opt}</div>
                </div>
            </div>`;
        });
        document.getElementById('options-area').innerHTML = optionsHtml;
    }

    function selectOption(idx, letter) {
        if (answered) return;
        answered = true;
        totalAnswered++;
        
        const q = questions[currentIdx];
        const isCorrect = (letter === q.correctAnswer);
        
        userAnswers.push(letter);
        reviewData.push({
            question: q.question,
            options: [
                { letter: 'A', text: q.optionA },
                { letter: 'B', text: q.optionB },
                { letter: 'C', text: q.optionC },
                { letter: 'D', text: q.optionD }
            ],
            selectedAnswer: letter,
            correctAnswer: q.correctAnswer,
            isCorrect: isCorrect,
            explanation: q.explanation
        });
        
        document.querySelectorAll('.quiz-option').forEach(el => el.classList.remove('active'));
        
        const letters = ['A', 'B', 'C', 'D'];
        const correctIdx = letters.indexOf(q.correctAnswer);
        
        if (isCorrect) {
            document.getElementById(`opt-${idx}`).classList.add('active');
            document.getElementById(`opt-${idx}`).style.borderColor = '#10b981';
            document.getElementById(`opt-${idx}`).style.background = 'rgba(16,185,129,0.05)';
            
            correctCount++;
            currentCombo++;
            if (currentCombo > maxCombo) maxCombo = currentCombo;
            
            const xpGained = q.xpReward + (currentCombo > 2 ? 5 : 0);
            sessionXp += xpGained;
            xp += xpGained;
            localStorage.setItem('lingo_xp', xp);
            
            document.getElementById('explanation-area').innerHTML = `<strong>Chính xác! (+${xpGained} XP)</strong><br/>${q.explanation || ''}`;
            document.getElementById('explanation-area').className = 'alert alert-success mt-3';
        } else {
            document.getElementById(`opt-${idx}`).style.borderColor = '#ef4444';
            document.getElementById(`opt-${idx}`).style.background = 'rgba(239,68,68,0.05)';
            
            if (correctIdx >= 0) {
                document.getElementById(`opt-${correctIdx}`).classList.add('active');
                document.getElementById(`opt-${correctIdx}`).style.borderColor = '#10b981';
            }
            
            currentCombo = 0;
            
            document.getElementById('explanation-area').innerHTML = `<strong>Sai rồi! Đáp án đúng là ${q.correctAnswer}.</strong><br/>${q.explanation || ''}`;
            document.getElementById('explanation-area').className = 'alert alert-danger mt-3';
        }
        
        document.getElementById('explanation-area').style.display = 'block';
        document.getElementById('btn-next').disabled = false;
        
        if (currentIdx === questions.length - 1) {
            document.getElementById('btn-next').innerHTML = 'Hoàn thành <i class="fa-solid fa-check"></i>';
        }
        
        updateStats();
    }
    
    function skipQuestion() {
        if (!answered) {
            const qSkip = questions[currentIdx];
            userAnswers.push("");
            reviewData.push({
                question: qSkip.question,
                options: [
                    { letter: 'A', text: qSkip.optionA },
                    { letter: 'B', text: qSkip.optionB },
                    { letter: 'C', text: qSkip.optionC },
                    { letter: 'D', text: qSkip.optionD }
                ],
                selectedAnswer: "",
                correctAnswer: qSkip.correctAnswer,
                isCorrect: false,
                explanation: qSkip.explanation
            });
            currentCombo = 0;
            updateStats();
        }
        nextQuestion();
    }

    function finishQuiz() {
        document.getElementById('progress-bar').style.width = '100%';
        document.getElementById('question-area').innerHTML = '';
        document.getElementById('options-area').innerHTML = '';
        document.getElementById('explanation-area').style.display = 'none';
        document.getElementById('quiz-actions').style.display = 'none';
        document.getElementById('quiz-finished').style.display = 'block';
        
        // Save to DB
        fetch('/Quiz/Submit', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: new URLSearchParams({
                '__RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '',
                'lessonId': lessonId,
                'comboXp': sessionXp
            }) + '&' + userAnswers.map(a => `answers=${a}`).join('&')
        }).then(res => res.json()).then(data => {
            console.log('Saved to DB', data);
        }).catch(err => console.error(err));
    }

    function updateStats() {
        document.getElementById('current-xp').innerText = sessionXp + ' XP';
        document.getElementById('lb-xp').innerText = xp + ' XP';
        document.getElementById('stat-correct').innerText = `${correctCount}/${totalAnswered}`;
        document.getElementById('stat-combo').innerText = currentCombo;
        document.getElementById('stat-max-combo').innerText = maxCombo;
        document.getElementById('stat-xp').innerText = sessionXp;
    }

    document.getElementById("reviewAnswersBtn")?.addEventListener("click", function () {
        const panel = document.getElementById("reviewPanel");
        const list = document.getElementById("reviewList");
        list.innerHTML = "";
        
        reviewData.forEach((item, index) => {
            let optionsHtml = '';
            item.options.forEach(opt => {
                let optClass = '';
                if (opt.letter === item.correctAnswer) optClass = 'is-correct';
                else if (opt.letter === item.selectedAnswer && !item.isCorrect) optClass = 'is-wrong';
                
                optionsHtml += `
                    <div class="review-option ${optClass}">
                        <strong>${opt.letter}.</strong> ${opt.text}
                    </div>
                `;
            });

            const html = `
                <div class="review-item ${item.isCorrect ? 'correct' : 'wrong'}">
                    <div class="d-flex justify-content-between mb-2">
                        <strong style="font-size: 15px;">Câu ${index + 1}: ${item.question}</strong>
                        ${item.isCorrect ? '<span class="badge bg-success align-self-start">Đúng</span>' : '<span class="badge bg-danger align-self-start">Sai</span>'}
                    </div>
                    <div class="mb-3">${optionsHtml}</div>
                    ${item.explanation ? `<div class="mt-2 text-secondary" style="font-size: 13px;"><i class="fa-solid fa-circle-info"></i> ${item.explanation}</div>` : ''}
                </div>
            `;
            list.insertAdjacentHTML('beforeend', html);
        });

        panel.style.display = "block";
        panel.scrollIntoView({ behavior: "smooth" });
    });

    document.getElementById("retryQuizBtn")?.addEventListener("click", function () {
        window.location.reload();
    });

    document.getElementById("closeReviewBtn")?.addEventListener("click", function () {
        document.getElementById("reviewPanel").style.display = "none";
        document.getElementById("quiz-finished").scrollIntoView({ behavior: "smooth" });
    });

    document.addEventListener("DOMContentLoaded", () => {
        updateStats();
        nextQuestion();
    });
</script>
}
}
