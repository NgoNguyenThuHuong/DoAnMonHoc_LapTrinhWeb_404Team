<!-- Auth Required Modal -->
<div class="auth-modal-overlay" id="authRequiredModal">
    <div class="auth-modal-card p-4">
        <div class="auth-modal-icon mb-3">
            <i class="fas fa-lock"></i>
        </div>
        <h3 class="fw-bold mb-3" style="font-size: 22px; color: #1e293b;">Đăng nhập để mở khóa<br/>trải nghiệm học tập đầy đủ</h3>
        
        <div class="text-start mb-4" style="background: rgba(16,185,129,0.05); padding: 16px; border-radius: 16px;">
            <p class="fw-bold text-dark mb-2" style="font-size: 14px;">Bạn cần đăng nhập để:</p>
            <ul class="list-unstyled text-secondary mb-0" style="font-size: 14px;">
                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Lưu tiến độ học</li>
                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Nhận XP và lên Level</li>
                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Ôn tập Smart SRS</li>
                <li><i class="fas fa-check-circle text-success me-2"></i> Theo dõi lịch sử học tập</li>
            </ul>
        </div>
        
        <div class="d-flex flex-column gap-2">
            <a href="#" class="btn btn-primary fw-bold py-2" id="authModalLoginBtn" style="border-radius: 14px; background: linear-gradient(135deg, #10B981, #3B82F6); border:none;">Đăng nhập</a>
            <a href="#" class="btn btn-light fw-bold py-2 border" id="authModalRegisterBtn" style="border-radius: 14px;">Đăng ký miễn phí</a>
        </div>
        
        <button onclick="hideAuthModal()" class="mt-3 w-100" style="background: none; border: none; color: #94a3b8; font-weight: 500; cursor: pointer; text-decoration: underline;">
            Tiếp tục khám phá
        </button>
    </div>
</div>
