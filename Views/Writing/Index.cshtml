@{
    ViewData["Title"] = "AI Writing Coach";
}

<style>
    .writing-tabs {
        display: flex;
        gap: 1.5rem;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        margin-bottom: 1rem;
    }
    .writing-tab {
        padding: 0.5rem 0;
        font-weight: 600;
        color: #64748b;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        transition: 0.2s;
        font-size: 14px;
    }
    .writing-tab.active {
        color: #10b981;
        border-bottom-color: #10b981;
    }
    .topic-badge {
        font-size: 11px;
        padding: 4px 12px;
        border-radius: 999px;
        background: rgba(0,0,0,0.03);
        color: #4b5563;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
    }
    .topic-badge:hover, .topic-badge.active {
        background: rgba(59,130,246,0.1);
        color: #3b82f6;
    }
    
    .criteria-item {
        display: flex;
        gap: 16px;
        padding: 12px;
        border-radius: 12px;
        transition: 0.2s;
    }
    .criteria-item:hover { background: rgba(0,0,0,0.02); }
    .criteria-icon {
        width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    
    .score-circle {
        position: relative;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        background: conic-gradient(#10b981 88%, #e2e8f0 0);
    }
    .score-circle-inner {
        width: 104px;
        height: 104px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }
    
    .progress-row-writing { margin-bottom: 12px; }
    .progress-row-writing .progress-label { display: flex; justify-content: space-between; font-size: 12px; font-weight: 600; margin-bottom: 4px; color: #4b5563;}
    .progress-row-writing .progress-bar-custom { height: 6px; border-radius: 3px; background: #e2e8f0; overflow: hidden; }
    .progress-row-writing .progress-bar-fill { height: 100%; border-radius: 3px; }
    
    .text-correction span.err { color: #ef4444; font-weight: 500; text-decoration: line-through; margin-right: 4px;}
    .text-correction span.corr { color: #10b981; font-weight: 600; }
</style>

<div class="animate-fade-in">
    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center gap-3">
            <div style="width: 56px; height: 56px; background: linear-gradient(135deg, #3B82F6, #8B5CF6); border-radius: 16px; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 16px rgba(59,130,246,0.2);">
                <i class="fa-solid fa-pen-nib text-white fs-4"></i>
            </div>
            <div>
                <h2 class="fw-bold m-0" style="font-size: 24px; color: #1e293b;">AI Writing Coach</h2>
                <p class="text-secondary m-0" style="font-size: 14px;">Chấm điểm và sửa lỗi bài viết tiếng Trung</p>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-light rounded-pill px-4 fw-bold" style="border: 1px solid rgba(0,0,0,0.05); font-size: 14px;">
                <i class="fa-regular fa-circle-question me-2"></i> Hướng dẫn
            </button>
            <button class="btn btn-light rounded-pill px-4 fw-bold" style="border: 1px solid rgba(0,0,0,0.05); font-size: 14px;">
                <i class="fa-solid fa-clock-rotate-left me-2"></i> Lịch sử bài viết
            </button>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column: Input -->
        <div class="col-lg-5">
            <div class="glass-card card mb-4" style="border-radius: 24px; padding: 24px;">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div style="width: 24px; height: 24px; background: #3b82f6; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 12px;">1</div>
                    <h5 class="fw-bold m-0 text-dark" style="font-size: 16px;">Nhập bài viết của bạn</h5>
                </div>
                
                <div class="p-2 mb-3" style="background: rgba(16,185,129,0.05); border-radius: 8px; border-left: 3px solid #10b981;">
                    <span class="text-success" style="font-size: 11px; font-weight: 600;"><i class="fa-solid fa-wand-magic-sparkles me-1"></i> Mẹo hay: Viết đoạn văn về chủ đề bạn thích, tối đa 500 chữ để AI chấm điểm chính xác nhất.</span>
                </div>

                <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
                    <span class="text-secondary" style="font-size: 12px; font-weight: 600;">Gợi ý chủ đề:</span>
                    <span class="topic-badge active" onclick="setTopic('Giới thiệu bản thân', this)">Giới thiệu bản thân</span>
                    <span class="topic-badge" onclick="setTopic('Kế hoạch cuối tuần', this)">Kế hoạch cuối tuần</span>
                    <span class="topic-badge" onclick="setTopic('Kỷ niệm đáng nhớ', this)">Kỷ niệm đáng nhớ</span>
                    <span class="topic-badge" onclick="setTopic('', this)">Khác <i class="fa-solid fa-chevron-down ms-1" style="font-size: 10px;"></i></span>
                </div>

                <div class="position-relative mb-3">
                    <textarea id="writing-input" class="form-control" rows="8" placeholder="Viết tiếng Trung tại đây..." style="border-radius: 16px; background: rgba(0,0,0,0.02); border: 1px solid rgba(0,0,0,0.05); padding: 16px; font-size: 14px; resize: none;"></textarea>
                    <div class="position-absolute text-secondary" style="bottom: 12px; left: 16px; font-size: 11px; font-weight: 500;" id="word-count">0/500 chữ</div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-6 d-flex align-items-center gap-2">
                        <label class="text-secondary m-0" style="font-size: 12px; font-weight: 600; white-space: nowrap;">Cấp độ mục tiêu:</label>
                        <select id="target-level" class="form-select form-select-sm border-0" style="background: rgba(0,0,0,0.03); border-radius: 8px; font-weight: 600; font-size: 13px;">
                            <option>HSK 1</option>
                            <option selected>HSK 2</option>
                            <option>HSK 3</option>
                            <option>HSK 4</option>
                            <option>HSK 5</option>
                            <option>HSK 6</option>
                        </select>
                    </div>
                    <div class="col-6 d-flex align-items-center gap-2">
                        <label class="text-secondary m-0" style="font-size: 12px; font-weight: 600; white-space: nowrap;">Loại bài viết:</label>
                        <select id="writing-type" class="form-select form-select-sm border-0" style="background: rgba(0,0,0,0.03); border-radius: 8px; font-weight: 600; font-size: 13px;">
                            <option selected>Đoạn văn tự do</option>
                            <option>Nhật ký</option>
                            <option>Thư từ / Email</option>
                            <option>Kể chuyện</option>
                            <option>Nghị luận</option>
                        </select>
                    </div>
                </div>

                <button id="btn-submit" onclick="evaluateWriting()" class="btn btn-primary w-100 fw-bold py-3 d-flex align-items-center justify-content-center gap-2" style="border-radius: 16px; background: linear-gradient(135deg, #3b82f6, #6366f1); border: none; box-shadow: 0 8px 24px rgba(59,130,246,0.3);">
                    <i class="fa-solid fa-wand-magic-sparkles"></i> Chấm bài ngay
                </button>
            </div>

            <!-- Tiêu chí chấm điểm -->
            <div>
                <h5 class="fw-bold mb-3 ms-2" style="font-size: 15px;">Tiêu chí chấm điểm</h5>
                <div class="criteria-item">
                    <div class="criteria-icon" style="background: rgba(245,158,11,0.1);"><i class="fa-solid fa-book text-warning fs-6"></i></div>
                    <div>
                        <div class="fw-bold text-dark" style="font-size: 13px;">Ngữ pháp</div>
                        <div class="text-secondary mt-1" style="font-size: 12px;">Sử dụng ngữ pháp chính xác, đúng cấu trúc</div>
                    </div>
                </div>
                <div class="criteria-item">
                    <div class="criteria-icon" style="background: rgba(16,185,129,0.1);"><i class="fa-solid fa-spell-check text-success fs-6"></i></div>
                    <div>
                        <div class="fw-bold text-dark" style="font-size: 13px;">Từ vựng</div>
                        <div class="text-secondary mt-1" style="font-size: 12px;">Sử dụng từ vựng phong phú, phù hợp ngữ cảnh</div>
                    </div>
                </div>
                <div class="criteria-item">
                    <div class="criteria-icon" style="background: rgba(59,130,246,0.1);"><i class="fa-solid fa-link text-primary fs-6"></i></div>
                    <div>
                        <div class="fw-bold text-dark" style="font-size: 13px;">Mạch ý & Liên kết</div>
                        <div class="text-secondary mt-1" style="font-size: 12px;">Bố cục rõ ràng, các ý liên kết chặt chẽ</div>
                    </div>
                </div>
                <div class="criteria-item">
                    <div class="criteria-icon" style="background: rgba(139,92,246,0.1);"><i class="fa-solid fa-face-smile text-purple" style="color: #8b5cf6;"></i></div>
                    <div>
                        <div class="fw-bold text-dark" style="font-size: 13px;">Độ tự nhiên</div>
                        <div class="text-secondary mt-1" style="font-size: 12px;">Diễn đạt tự nhiên như người bản xứ</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Results (Hidden initially) -->
        <div class="col-lg-7" id="results-area" style="display: none;">
            
            <!-- Ket qua cham diem -->
            <div class="glass-card card mb-4" style="border-radius: 24px; padding: 24px; position: relative;">
                <div class="position-absolute" style="top: 24px; right: 24px;">
                    <span class="badge" style="background: rgba(139,92,246,0.1); color: #8b5cf6; padding: 6px 12px; border-radius: 999px;"><i class="fa-solid fa-bolt me-1"></i> AI đã chấm</span>
                </div>

                <div class="d-flex align-items-center gap-2 mb-4">
                    <div style="width: 24px; height: 24px; background: #3b82f6; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 12px;">2</div>
                    <h5 class="fw-bold m-0 text-dark" style="font-size: 16px;">Kết quả chấm điểm</h5>
                </div>

                <div class="row align-items-center">
                    <div class="col-md-4 text-center border-end">
                        <div class="text-secondary fw-bold mb-3" style="font-size: 13px;">Tổng điểm</div>
                        <div id="total-score-circle" class="score-circle mx-auto mb-3">
                            <div class="score-circle-inner">
                                <span id="total-score-text" class="fw-bold text-success" style="font-size: 36px; line-height: 1;">88</span>
                                <span class="text-secondary" style="font-size: 12px; font-weight: 600;">/100</span>
                            </div>
                        </div>
                        <div id="score-feedback" class="fw-bold text-dark" style="font-size: 14px;">Tuyệt vời! 🎉</div>
                        <div id="score-feedback-sub" class="text-secondary mt-1 px-2" style="font-size: 11px;">Bài viết của bạn rất tốt! Hãy tiếp tục phát huy nhé.</div>
                    </div>
                    
                    <div class="col-md-4 px-4">
                        <div class="progress-row-writing">
                            <div class="progress-label"><span>Ngữ pháp</span><span id="grammar-score">90/100</span></div>
                            <div class="progress-bar-custom"><div id="grammar-bar" class="progress-bar-fill bg-primary" style="width: 90%;"></div></div>
                        </div>
                        <div class="progress-row-writing">
                            <div class="progress-label"><span>Từ vựng</span><span id="vocab-score">85/100</span></div>
                            <div class="progress-bar-custom"><div id="vocab-bar" class="progress-bar-fill bg-success" style="width: 85%;"></div></div>
                        </div>
                        <div class="progress-row-writing">
                            <div class="progress-label"><span>Mạch ý & Liên kết</span><span id="coherence-score">90/100</span></div>
                            <div class="progress-bar-custom"><div id="coherence-bar" class="progress-bar-fill bg-primary" style="width: 90%;"></div></div>
                        </div>
                        <div class="progress-row-writing">
                            <div class="progress-label"><span>Độ tự nhiên</span><span id="naturalness-score">87/100</span></div>
                            <div class="progress-bar-custom"><div id="naturalness-bar" class="progress-bar-fill bg-primary" style="width: 87%;"></div></div>
                        </div>
                    </div>

                    <div class="col-md-4 pl-3" style="border-left: 1px solid rgba(0,0,0,0.05);">
                        <div class="p-3 h-100 d-flex flex-column justify-content-center" style="background: rgba(0,0,0,0.02); border-radius: 16px;">
                            <div class="text-dark fw-bold mb-2" style="font-size: 13px;">Cấp độ ước lượng</div>
                            <div id="estimated-hsk" class="fw-bold text-success" style="font-size: 28px;">HSK 2</div>
                            <div class="text-secondary fw-bold mb-2" style="font-size: 11px;">Trình độ hiện tại</div>
                            <div class="text-secondary" style="font-size: 11px; line-height: 1.5; margin-bottom: 12px;">Bài viết của bạn phù hợp với trình độ hiện tại.</div>
                            <a href="#" class="text-primary fw-bold text-decoration-none" style="font-size: 12px;">Xem gợi ý học tập &rarr;</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bai viet da sua & gop y -->
            <div class="glass-card card mb-4" style="border-radius: 24px; padding: 24px;">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div style="width: 24px; height: 24px; background: #3b82f6; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 12px;">3</div>
                    <h5 class="fw-bold m-0 text-dark" style="font-size: 16px;">Bài viết đã được sửa & góp ý</h5>
                </div>

                <div class="writing-tabs">
                    <div class="writing-tab" onclick="switchTab(0, this)">Bài viết gốc</div>
                    <div class="writing-tab active" onclick="switchTab(1, this)">Bài viết đã sửa</div>
                    <div class="writing-tab" onclick="switchTab(2, this)">Phân tích lỗi</div>
                    <div class="writing-tab" onclick="switchTab(3, this)">Từ vựng nâng cao</div>
                </div>

                <div id="tab-content-0" class="text-correction p-3 mb-3" style="display:none; background: white; border: 1px solid rgba(0,0,0,0.05); border-radius: 16px; font-size: 14px; line-height: 1.8; color: #1e293b; min-height: 120px;">
                    <!-- Original Text Filled by JS -->
                </div>

                <div id="tab-content-1" class="text-correction p-3 mb-3" style="background: white; border: 1px solid rgba(0,0,0,0.05); border-radius: 16px; font-size: 14px; line-height: 1.8; color: #1e293b; min-height: 120px;">
                    <!-- Corrected HTML Filled by JS -->
                </div>

                <div id="tab-content-2" class="p-3 mb-3" style="display:none; background: white; border: 1px solid rgba(0,0,0,0.05); border-radius: 16px; font-size: 14px; line-height: 1.8; color: #1e293b; min-height: 120px;">
                    <ul id="error-analysis-list" class="text-secondary m-0" style="padding-left: 20px;">
                        <!-- Filled by JS -->
                    </ul>
                </div>

                <div id="tab-content-3" class="p-3 mb-3" style="display:none; background: white; border: 1px solid rgba(0,0,0,0.05); border-radius: 16px; font-size: 14px; line-height: 1.8; color: #1e293b; min-height: 120px;">
                    <div id="advanced-vocab-list" class="d-flex flex-wrap gap-2">
                        <!-- Filled by JS -->
                    </div>
                </div>

                <div class="p-3 position-relative" style="background: rgba(59,130,246,0.05); border-radius: 16px; font-size: 13px; color: #4b5563; line-height: 1.6;">
                    <span class="position-absolute" style="top: 12px; right: 16px; font-size: 11px; font-weight: 600; color: #3b82f6;">Dịch nghĩa</span>
                    <span id="translated-text-box"><!-- Filled by JS --></span>
                </div>
            </div>

            <!-- Gợi ý cải thiện -->
            <div class="glass-card card mb-4" style="border-radius: 24px; padding: 24px;">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="fa-solid fa-lightbulb text-warning fs-5"></i>
                    <h5 class="fw-bold m-0 text-dark" style="font-size: 15px;">Gợi ý cải thiện</h5>
                </div>
                <ul id="suggestions-list" class="text-secondary m-0" style="font-size: 13px; padding-left: 20px; line-height: 1.8;">
                    <!-- Filled by JS -->
                </ul>
            </div>

            <!-- Buttons -->
            <div class="d-flex justify-content-end gap-3">
                <button class="btn btn-light fw-bold px-4" style="border-radius: 12px; border: 1px solid rgba(0,0,0,0.1); color: #4b5563;">
                    <i class="fa-solid fa-rotate-right me-2"></i> Luyện lại bài viết này
                </button>
                <button class="btn btn-primary fw-bold px-4" style="border-radius: 12px; background: linear-gradient(135deg, #8b5cf6, #6366f1); border: none;">
                    <i class="fa-solid fa-pen me-2"></i> Tạo bài viết mới
                </button>
            </div>

        </div>

        <!-- Initial Placeholder State (Before grading) -->
        <div class="col-lg-7" id="initial-placeholder">
            <div class="h-100 w-100 d-flex flex-column align-items-center justify-content-center p-5" style="border: 2px dashed rgba(0,0,0,0.05); border-radius: 24px; background: rgba(255,255,255,0.5);">
                <img src="https://cdn-icons-png.flaticon.com/512/8345/8345155.png" alt="AI Robot" style="width: 120px; opacity: 0.5; margin-bottom: 24px; filter: grayscale(100%);">
                <h4 class="text-secondary fw-bold mb-2">Đang chờ bài viết của bạn...</h4>
                <p class="text-secondary text-center" style="font-size: 14px; max-width: 300px;">Viết một đoạn văn tiếng Trung và nhấn "Chấm bài ngay" để AI phân tích và chấm điểm nhé!</p>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    const textarea = document.getElementById('writing-input');
    const wordCount = document.getElementById('word-count');
    
    // Add default text for testing to match screenshot quickly
    textarea.value = "我叫小明，我今年二十岁，我是学生。我在越南学习中文已经两年了。我喜欢中文，因为中文很有趣，而且很有用。我的爱好是听音乐和看电影。周末的时候，我常常和朋友一起去喝咖啡或者去公园散步。未来，我希望可以去中国留学，然后找到一份好工作。";

    function switchTab(index, element) {
        document.querySelectorAll('.writing-tab').forEach(el => el.classList.remove('active'));
        element.classList.add('active');
        
        for(let i=0; i<4; i++) {
            const content = document.getElementById('tab-content-' + i);
            if (content) content.style.display = 'none';
        }
        const targetContent = document.getElementById('tab-content-' + index);
        if (targetContent) targetContent.style.display = 'block';
    }

    // Auto update word count
    function updateWordCount() {
        const text = textarea.value.trim();
        const chars = text.replace(/[\s\n\p{P}]/gu, '').length; // Count Chinese characters roughly
        wordCount.innerText = chars + '/500 chữ';
    }
    textarea.addEventListener('input', updateWordCount);
    updateWordCount();

    function setTopic(topic, element) {
        // Update active class
        document.querySelectorAll('.topic-badge').forEach(el => el.classList.remove('active'));
        element.classList.add('active');

        // Set text
        if (topic === 'Giới thiệu bản thân') {
            textarea.value = "我叫小明，我今年二十岁，我是学生。我在越南学习中文已经两年了。我喜欢中文，因为中文很有趣，而且很有用。";
        } else if (topic === 'Kế hoạch cuối tuần') {
            textarea.value = "这个周末，我打算和朋友一起去市中心看电影。电影结束后，我们会去一家新开的中国餐厅吃晚饭。星期天我想在家休息，读一本书。";
        } else if (topic === 'Kỷ niệm đáng nhớ') {
            textarea.value = "我最难忘的经历是去年去北京旅游。我参观了长城和故宫，吃了北京烤鸭。那里的人很热情，风景也非常漂亮。我希望以后还有机会去中国。";
        } else {
            textarea.value = "";
        }
        updateWordCount();
    }

    async function evaluateWriting() {
        const btn = document.getElementById('btn-submit');
        const text = textarea.value.trim();
        
        if (text.length === 0) {
            alert('Vui lòng nhập bài viết trước khi chấm điểm.');
            return;
        }

        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> AI đang phân tích...';
        btn.disabled = true;

        try {
            const response = await fetch('/Ai/EvaluateWriting', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ text: text })
            });
            const data = await response.json();
            
            if (data.totalScore !== undefined) {
                // Populate Results
                document.getElementById('total-score-text').innerText = data.totalScore;
                document.getElementById('total-score-circle').style.background = `conic-gradient(#10b981 ${data.totalScore}%, #e2e8f0 0)`;
                
                document.getElementById('score-feedback-sub').innerText = data.feedback || 'Bài viết khá tốt!';
                
                document.getElementById('grammar-score').innerText = `${data.grammarScore}/100`;
                document.getElementById('grammar-bar').style.width = `${data.grammarScore}%`;
                
                document.getElementById('vocab-score').innerText = `${data.vocabularyScore}/100`;
                document.getElementById('vocab-bar').style.width = `${data.vocabularyScore}%`;
                
                document.getElementById('coherence-score').innerText = `${data.coherenceScore}/100`;
                document.getElementById('coherence-bar').style.width = `${data.coherenceScore}%`;
                
                document.getElementById('naturalness-score').innerText = `${data.naturalnessScore}/100`;
                document.getElementById('naturalness-bar').style.width = `${data.naturalnessScore}%`;
                
                document.getElementById('estimated-hsk').innerText = data.estimatedHsk;
                
                document.getElementById('tab-content-0').innerText = text; // Original text
                document.getElementById('tab-content-1').innerHTML = data.correctedHtml;
                document.getElementById('translated-text-box').innerText = data.translatedText;
                
                const errors = data.errorAnalysis || [];
                if (errors.length > 0) {
                    document.getElementById('error-analysis-list').innerHTML = errors.map(e => `<li><span class="text-danger fw-bold">${e.original}</span> &rarr; <span class="text-success fw-bold">${e.corrected}</span>: ${e.explanation}</li>`).join('');
                } else {
                    document.getElementById('error-analysis-list').innerHTML = '<li>Không tìm thấy lỗi nào đáng kể! Bài viết rất tốt.</li>';
                }

                const vocab = data.advancedVocabulary || [];
                if (vocab.length > 0) {
                    document.getElementById('advanced-vocab-list').innerHTML = vocab.map(v => `<span class="badge bg-light text-dark border p-2">${v.word} (${v.pinyin}) - ${v.meaning}</span>`).join('');
                } else {
                    document.getElementById('advanced-vocab-list').innerHTML = '<span class="text-secondary">Chưa có từ vựng nâng cao nào được gợi ý.</span>';
                }

                const suggs = data.suggestions || [];
                document.getElementById('suggestions-list').innerHTML = suggs.map(s => `<li>${s}</li>`).join('');
                
                // Show Results Area
                document.getElementById('initial-placeholder').style.display = 'none';
                document.getElementById('results-area').style.display = 'block';
                
                // Scroll to results on mobile
                if (window.innerWidth < 992) {
                    document.getElementById('results-area').scrollIntoView({behavior: 'smooth'});
                }
            } else {
                alert("Lỗi khi chấm điểm: " + (data.message || "Không có phản hồi"));
            }
        } catch (error) {
            console.error("Error evaluating writing:", error);
            alert("Đã xảy ra lỗi kết nối với máy chủ AI.");
        } finally {
            btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> Chấm bài ngay';
            btn.disabled = false;
        }
    }
</script>
}
